# GoCognigo Environment Configuration
# Copy this file to .env and fill in your API keys

# Default LLM provider: anthropic or huggingface
LLM_PROVIDER=anthropic

# API Keys (at least one LLM key required)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
HUGGINGFACE_API_KEY=

# Embedding provider: openai or huggingface
EMBEDDING_PROVIDER=openai
EMBEDDING_API_KEY=

# Server port (default: 8080)
PORT=8080

# OCR provider for scanned PDFs: tesseract, sarvam, or leave empty for auto-detect
# Auto-detect prefers Tesseract (free, local) and falls back to Sarvam (paid, cloud)
OCR_PROVIDER=
SARVAM_API_KEY=

# Firebase Auth (optional — leave blank for local dev without auth)
# Get these from Firebase Console > Project Settings > Web App
FIREBASE_PROJECT_ID=
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=
