# ============================================================
#  GoCognigo — Environment Configuration
#  Copy this file to .env and fill in your values.
#  .env is gitignored and never committed.
# ============================================================

# ------------------------------------------------------------
# Server
# ------------------------------------------------------------
PORT=8080

# ------------------------------------------------------------
# Firebase Authentication
# Get these from: Firebase Console → Project Settings →
# Your apps → Web app → Config snippet
#
# Leave all FIREBASE_* vars blank (or remove them) to run in
# local-dev mode with no login required.
# ------------------------------------------------------------
FIREBASE_PROJECT_ID=
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=

# ------------------------------------------------------------
# Admin
# Set to your Firebase UID to allow GET /api/feedback
# Find your UID: Firebase Console → Authentication → Users
# ------------------------------------------------------------
ADMIN_UID=

# ------------------------------------------------------------
# GitHub Integration (feature request → GitHub Issues)
# GITHUB_TOKEN: Personal Access Token with repo:write scope
#   Create at: GitHub → Settings → Developer settings → PATs → Fine-grained
#   Permissions needed: Issues (Read & Write)
# GITHUB_REPO: owner/repo  e.g. your-org/gocognigo
# Leave blank to disable (requests still saved to data/feedback.json)
# ------------------------------------------------------------
GITHUB_TOKEN=
GITHUB_REPO=
